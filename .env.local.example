# AI Translation Lab - Environment Variables
# Copy this file to .env.local and fill in your API keys
# NEVER commit .env.local to version control!

# ===========================================
# Server-Side API Keys (Optional but Recommended)
# If configured, these will be used instead of client-side keys
# ===========================================

# Google Gemini API Key
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# Groq API Key
# Get from: https://console.groq.com/keys
GROQ_API_KEY=

# NVIDIA NIM API Key
# Get from: https://build.nvidia.com/
NVIDIA_API_KEY=

# OpenRouter API Key
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Custom Provider API Key (optional)
CUSTOM_API_KEY=

# Custom Provider Endpoint URL (optional)
CUSTOM_API_ENDPOINT=

# ===========================================
# Application Configuration
# ===========================================

# Node environment (development | production)
NODE_ENV=development

# Port for development server (default: 3000)
PORT=3000

# ===========================================
# Security (Optional)
# ===========================================

# Enable strict HTTPS redirect in production (default: true in prod)
# FORCE_HTTPS=true

# Rate limit (requests per minute)
# RATE_LIMIT=10
